{
  "name": "@devsadikbd/bd-validator",
  "version": "1.0.0",
  "description": "A utility library for validating Bangladeshi phone numbers, NID, TIN, passport, postal codes and bank accounts.",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsup src/index.ts --format cjs,esm --dts",
    "test": "jest",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "bangladesh",
    "bd",
    "validator",
    "phone",
    "nid",
    "tin",
    "passport",
    "postal",
    "bangla",
    "validation",
    "utility"
  ],
  "author": "Md Sadik Hasan <devsadikbd@gmail.com> (https://github.com/devsadikbd)",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/devsadikbd/bd-validator.git"
  },
  "homepage": "https://github.com/devsadikbd/bd-validator#readme",
  "bugs": {
    "url": "https://github.com/devsadikbd/bd-validator/issues"
  },
  "devDependencies": {
    "@types/jest": "^29.5.0",
    "jest": "^29.5.0",
    "ts-jest": "^29.1.0",
    "tsup": "^7.2.0",
    "typescript": "^5.0.0"
  },
  "files": [
    "dist"
  ]
}
